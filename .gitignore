# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
.hypothesis/
dist/
build/

# Local cache (personal listening data — never committed; privacy: local-first)
data/*.db
data/*.sqlite
data/*.sqlite3

# Secrets — API keys live in the environment / .env, never in source
.env
*.secret

# Generated a11y artifacts that include timestamps are committed under docs/audits/
# but the raw browser dumps are not.
docs/audits/pa11y-raw.json
# coverage.xml is regenerable machine churn (pytest, see pyproject.toml), not a
# committed deliverable (unlike eval-report.json / the a11y dashboards).
docs/audits/coverage.xml
node_modules/

# OS
.DS_Store
